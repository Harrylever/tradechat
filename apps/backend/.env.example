# Database
DATABASE_URL="postgresql://..."

# Twilio
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxx"
TWILIO_WHATSAPP_NUMBER="whatsapp:+141..."

# Gemini
GEMINI_API_KEY="AIza..."

# Nomba — loaded from env ONLY, never hardcoded
NOMBA_ACCOUNT_ID="<your-parent-account-UUID>"   # from Nomba sandbox dashboard
NOMBA_SUBACCOUNT_ID="<your-sub-account-UUID>"
NOMBA_CLIENT_ID="<client-id>"
NOMBA_CLIENT_SECRET="<client-secret>"            # only used for initial token issue
NOMBA_WEBHOOK_SECRET="<signature-key>"           # set in Nomba 
NOMBA_DEFAULT_EMAIL="orders@tradechat.com"

# Redis (Upstash)
REDIS_URL="redis://..."

# Sentry Monitoring
SENTRY_DSN="https://..."

# Internal
PORT=3002
ALLOWED_ORIGINS="http://localhost:3001"
JWT_SECRET="<jwt-super-duper-secret-key>"
JWT_EXPIRES_IN=7d
WEB_APP_URL="http://localhost:3000"

# Log monitoring
LOGTAIL_SOURCE_TOKEN="xxx..."
LOGTAIL_INGESTING_HOST="xxx..."
